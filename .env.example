# ============================================
# Magsil Móveis — Environment Variables
# ============================================
# Copie este arquivo para .env e preencha os valores

# ─── Supabase (auth + leads) ─────────────────
# https://supabase.com/dashboard
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Sanity CMS (conteúdo) ───────────────────
# https://sanity.io/manage → novo projeto → obtenha o Project ID
PUBLIC_SANITY_PROJECT_ID=your-sanity-project-id
PUBLIC_SANITY_DATASET=production
# Token com permissão de leitura (para o script de indexação)
SANITY_API_TOKEN=

# ─── Algolia Search ──────────────────────────
# https://dashboard.algolia.com → Settings → API Keys
PUBLIC_ALGOLIA_APP_ID=your-algolia-app-id
PUBLIC_ALGOLIA_SEARCH_KEY=your-search-only-api-key
# Chave de escrita (apenas server-side, NÃO expor no frontend)
ALGOLIA_WRITE_KEY=your-admin-api-key

# ─── OpenAI (chatbot IA) ─────────────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ─── Pinecone (RAG / vector database) ────────
# https://app.pinecone.io → API Keys
PINECONE_API_KEY=
PINECONE_INDEX=magsilmoveis

# ─── Resend (email) ──────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=

# ─── Cloudflare Turnstile (CAPTCHA) ──────────
# https://dash.cloudflare.com → Turnstile
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ─── Site ─────────────────────────────────────
PUBLIC_SITE_URL=https://magsilmoveis.com.br
PUBLIC_WHATSAPP_NUMBER=5582999999999
PUBLIC_CONTACT_EMAIL=contato@magsilmoveis.com.br

# ─── Social ───────────────────────────────────
INSTAGRAM_ACCESS_TOKEN=
