---



import '../styles/globals.css';
import BaseHead from '../components/layout/BaseHead.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import ChatWidget from '../components/ui/ChatWidget.astro';
import { VisualEditing } from '@sanity/astro/visual-editing';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  noindex?: boolean;
}

const props = Astro.props;

// Visual Editing apenas em ambientes de preview (nunca em produção pública)
const visualEditingEnabled =
  import.meta.env.PUBLIC_SANITY_VISUAL_EDITING_ENABLED === 'true';
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    
    <BaseHead {...props} />
    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col bg-offwhite text-text-primary antialiased">
    <!-- Skip to content (accessibility) -->
    <a href="#main-content" class="skip-to-content" id="skip-link">
      Pular para o conteúdo principal
    </a>

    <!-- Header -->
    <slot name="header">
      <Header />
    </slot>

    <!-- Main Content -->
    <main id="main-content" class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <Footer />

    <!-- Chat Widget WhatsApp (guiado) -->
    <ChatWidget />

    <!-- Chatbot IA — carrega apenas quando o botão estiver próximo da viewport -->

    <!-- Visual Editing overlays (apenas em ambiente de preview) -->
    <VisualEditing enabled={visualEditingEnabled} />

    <!-- Scroll reveal -->
    <script src="../scripts/animations.ts"></script>
  </body>
</html>
