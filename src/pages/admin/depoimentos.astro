---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import Badge from '../../components/admin/Badge.astro';
import { MessageSquare, Plus, Search, Star, Edit, Trash2 } from 'lucide-react';

let testimonials: Array<{id: string; author_name: string; author_role: string | null; content: string; rating: number; active: boolean; created_at: string}> = [];
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;

if (supabaseUrl) {
  try {
    const { createSupabaseAdmin } = await import('../../lib/supabase');
    const supabase = createSupabaseAdmin();
    const { data } = await supabase.from('testimonials').select('*').order('created_at', { ascending: false });
    testimonials = data || [];
  } catch (e) { console.error('Testimonials fetch error:', e); }
}

function formatDate(d: string): string {
  return new Date(d).toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit', year: 'numeric' });
}
---

<AdminLayout title="Depoimentos" breadcrumb="Depoimentos">

  <!-- Toolbar -->
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-6">
    <div class="relative">
      <Search className="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-admin-text-muted" />
      <input
        type="text"
        aria-label="Buscar depoimento"
        class="pl-9 pr-4 py-2 text-sm bg-admin-surface border border-admin-border rounded-lg focus:outline-none focus:ring-1 focus:ring-admin-accent text-admin-text w-64"
      />
    </div>
    <button disabled={!supabaseUrl} class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium bg-admin-accent text-white rounded-lg hover:bg-admin-accent-hover transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
      <Plus className="w-4 h-4" /> Adicionar Depoimento
    </button>
  </div>

  <!-- Table -->
  <div class="bg-admin-surface border border-admin-border rounded-lg overflow-hidden">
    <div class="px-6 py-4 border-b border-admin-border">
      <h2 class="text-sm font-semibold text-admin-text">Depoimentos — <span class="text-admin-text-muted font-normal">{testimonials.length} registros</span></h2>
    </div>

    {testimonials.length > 0 ? (
      <div class="overflow-x-auto">
        <table class="w-full text-sm text-left">
          <thead>
            <tr class="bg-admin-surface-hover border-b border-admin-border text-xs font-semibold text-admin-text-muted uppercase tracking-wider">
              <th class="py-3 px-6">Autor</th>
              <th class="py-3 px-6">Depoimento</th>
              <th class="py-3 px-6">Avaliação</th>
              <th class="py-3 px-6">Status</th>
              <th class="py-3 px-6 text-right">Ações</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-admin-border">
            {testimonials.map((t) => (
              <tr class="hover:bg-admin-surface-hover transition-colors group">
                <td class="py-3 px-6">
                  <p class="font-medium text-admin-text">{t.author_name}</p>
                  {t.author_role && <p class="text-xs text-admin-text-muted">{t.author_role}</p>}
                  <p class="text-xs text-admin-text-muted">{formatDate(t.created_at)}</p>
                </td>
                <td class="py-3 px-6 max-w-xs">
                  <p class="text-sm text-admin-text-muted truncate">{t.content}</p>
                </td>
                <td class="py-3 px-6">
                  <div class="flex items-center gap-0.5">
                    {Array.from({ length: 5 }).map((_, i) => (
                      <Star className={`w-3.5 h-3.5 ${i < t.rating ? 'fill-amber-400 text-amber-400' : 'fill-gray-200 text-gray-200'}`} />
                    ))}
                  </div>
                </td>
                <td class="py-3 px-6">
                  <Badge 
                    text={t.active ? 'Visível' : 'Oculto'} 
                    variant={t.active ? 'success' : 'neutral'} 
                    dot={true} 
                  />
                </td>
                <td class="py-3 px-6">
                  <div class="flex items-center justify-end gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                    <button class="p-1.5 text-admin-text-muted hover:text-admin-text hover:bg-admin-surface-hover rounded transition-colors" aria-label="Editar">
                      <Edit className="w-4 h-4" />
                    </button>
                    <button class="p-1.5 text-admin-text-muted hover:text-admin-danger hover:bg-red-50 rounded transition-colors" aria-label="Excluir">
                      <Trash2 className="w-4 h-4" />
                    </button>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    ) : (
      <div class="p-16 flex flex-col items-center justify-center text-center">
        <MessageSquare className="w-8 h-8 text-admin-text-muted mb-3" />
        <h3 class="text-base font-semibold text-admin-text mb-1">Nenhum depoimento</h3>
        <p class="text-sm text-admin-text-muted mb-6">
          {supabaseUrl ? 'Adicione o primeiro depoimento de cliente.' : 'Configure PUBLIC_SUPABASE_URL para começar.'}
        </p>
        <button disabled={!supabaseUrl} class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium bg-admin-accent text-white rounded-lg hover:bg-admin-accent-hover transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
          <Plus className="w-4 h-4" /> Adicionar Depoimento
        </button>
      </div>
    )}
  </div>

</AdminLayout>
