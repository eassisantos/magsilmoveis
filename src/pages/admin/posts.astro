---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import Badge from '../../components/admin/Badge.astro';
import { FileText, Plus, Eye, Edit, Trash2, ExternalLink } from 'lucide-react';

let posts: Array<{id: string; title: string; slug: string; status: string; created_at: string; published_at: string | null}> = [];
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;

if (supabaseUrl) {
  try {
    const { createSupabaseAdmin } = await import('../../lib/supabase');
    const supabase = createSupabaseAdmin();
    const { data } = await supabase.from('blog_posts').select('id, title, slug, status, created_at, published_at').order('created_at', { ascending: false });
    posts = data || [];
  } catch (e) { console.error('Posts fetch error:', e); }
}

const statusMap: Record<string, { label: string; variant: string }> = {
  published: { label: 'Publicado', variant: 'success' },
  scheduled: { label: 'Agendado', variant: 'warning' },
  draft: { label: 'Rascunho', variant: 'neutral' },
};

function formatDate(d: string | null): string {
  if (!d) return '—';
  return new Date(d).toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit', year: '2-digit' });
}
---

<AdminLayout title="Posts" breadcrumb="Posts">

  <!-- Filter Tabs + New Post -->
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
    <div class="inline-flex items-center gap-0.5 bg-white border border-admin-border rounded-xl p-1">
      {['Todos', 'Publicados', 'Agendados', 'Rascunhos'].map((tab) => (
        <button
          class={`px-4 py-2 text-sm rounded-lg transition-colors ${tab === 'Todos' ? 'bg-admin-accent text-white font-medium' : 'text-admin-text-muted hover:text-admin-text hover:bg-admin-surface-hover'}`}
        >
          {tab}
        </button>
      ))}
    </div>
    <a href="/admin/posts/novo" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium bg-admin-accent text-white rounded-lg hover:bg-admin-accent-hover transition-colors">
      <Plus className="w-4 h-4" /> Novo Post
    </a>
  </div>

  <!-- Table -->
  <div class="bg-white border border-admin-border rounded-xl overflow-hidden">

    {posts.length > 0 ? (
      <div class="overflow-x-auto">
        <table class="w-full text-sm text-left" aria-label="Lista de posts do blog">
          <thead>
            <tr class="bg-admin-surface-hover border-b border-admin-border text-[11px] font-semibold text-admin-text-muted uppercase tracking-widest">
              <th class="py-3 px-6">Título</th>
              <th class="py-3 px-6">Criado</th>
              <th class="py-3 px-6">Status</th>
              <th class="py-3 px-6 text-right">Ações</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-admin-border">
            {posts.map((post) => {
              const s = statusMap[post.status] || { label: post.status, variant: 'neutral' };
              return (
                <tr class="hover:bg-admin-surface-hover transition-colors group">
                  <td class="py-4 px-6">
                    <p class="font-medium text-admin-text leading-snug">{post.title}</p>
                    <p class="text-xs text-admin-text-muted font-mono mt-0.5 opacity-70">/blog/{post.slug}</p>
                  </td>
                  <td class="py-4 px-6 text-admin-text-muted whitespace-nowrap">{formatDate(post.created_at)}</td>
                  <td class="py-4 px-6">
                    <Badge text={s.label} variant={s.variant as any} dot={true} />
                  </td>
                  <td class="py-4 px-6">
                    <div class="flex items-center justify-end gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                      <a href={`/blog/${post.slug}`} target="_blank" class="p-1.5 text-admin-text-muted hover:text-admin-text hover:bg-admin-surface-hover rounded transition-colors" aria-label="Ver no blog">
                        <ExternalLink className="w-4 h-4" />
                      </a>
                      <button class="p-1.5 text-admin-text-muted hover:text-admin-text hover:bg-admin-surface-hover rounded transition-colors" aria-label="Editar">
                        <Edit className="w-4 h-4" />
                      </button>
                      {post.status === 'published' ? (
                        <button class="p-1.5 text-admin-text-muted hover:text-amber-600 hover:bg-amber-50 rounded transition-colors" aria-label="Mover para rascunho">
                          <Eye className="w-4 h-4" />
                        </button>
                      ) : (
                        <button class="p-1.5 text-admin-text-muted hover:text-emerald-600 hover:bg-emerald-50 rounded transition-colors" aria-label="Publicar">
                          <Eye className="w-4 h-4" />
                        </button>
                      )}
                      <button class="p-1.5 text-admin-text-muted hover:text-admin-danger hover:bg-red-50 rounded transition-colors" aria-label="Excluir">
                        <Trash2 className="w-4 h-4" />
                      </button>
                    </div>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    ) : (
      <div class="p-16 flex flex-col items-center justify-center text-center">
        <FileText className="w-8 h-8 text-admin-border mb-3" />
        <h3 class="text-base font-semibold text-admin-text mb-1">Nenhum post encontrado</h3>
        <p class="text-sm text-admin-text-muted mb-6">
          {supabaseUrl ? 'Crie o primeiro artigo para o blog.' : 'Configure PUBLIC_SUPABASE_URL para começar.'}
        </p>
        <button disabled={!supabaseUrl} class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium bg-admin-accent text-white rounded-lg hover:bg-admin-accent-hover transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
          <Plus className="w-4 h-4" /> Novo Post
        </button>
      </div>
    )}
  </div>

</AdminLayout>
