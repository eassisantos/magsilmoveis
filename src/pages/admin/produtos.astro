---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import Badge from '../../components/admin/Badge.astro';
import { Package, Plus, Star, Search, Filter, Edit, Trash2 } from 'lucide-react';

let products: Array<{id: string; name: string; category: string; active: boolean; featured: boolean; created_at: string}> = [];
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;

if (supabaseUrl) {
  try {
    const { createSupabaseAdmin } = await import('../../lib/supabase');
    const supabase = createSupabaseAdmin();
    const { data } = await supabase.from('products').select('id, name, category, active, featured, created_at').order('sort_order', { ascending: true });
    products = data || [];
  } catch (e) { console.error('Products fetch error:', e); }
}

const categoryLabels: Record<string, string> = {
  poltronas: 'Poltronas',
  mesas: 'Mesas & Cadeiras',
  area_externa: 'Área Externa',
  banquetas: 'Banquetas',
  chaises: 'Chaises'
};
---

<AdminLayout title="Produtos" breadcrumb="Produtos">

  <!-- Header Actions -->
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
    <div class="relative">
      <Search className="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-admin-text-muted" />
      <input
        type="text"
        placeholder="Buscar produto..."
        class="pl-9 pr-4 py-2 text-sm bg-admin-surface border border-admin-border rounded-lg focus:outline-none focus:ring-1 focus:ring-admin-accent text-admin-text placeholder:text-admin-text-muted w-64"
      />
    </div>
    <div class="flex items-center gap-2">
      <button class="inline-flex items-center gap-2 px-3 py-2 text-sm font-medium bg-admin-surface border border-admin-border rounded-lg text-admin-text-muted hover:bg-admin-surface-hover transition-colors">
        <Filter className="w-4 h-4" /> Filtros
      </button>
      <button disabled={!supabaseUrl} class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium bg-admin-accent text-white rounded-lg hover:bg-admin-accent-hover transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
        <Plus className="w-4 h-4" /> Novo Produto
      </button>
    </div>
  </div>

  <!-- Products Table -->
  <div class="bg-admin-surface border border-admin-border rounded-lg overflow-hidden">
    <div class="px-6 py-4 border-b border-admin-border flex items-center justify-between">
      <h2 class="text-sm font-semibold text-admin-text">Catálogo — <span class="text-admin-text-muted font-normal">{products.length} produtos</span></h2>
    </div>

    {products.length > 0 ? (
      <div class="overflow-x-auto">
        <table class="w-full text-sm text-left">
          <thead>
            <tr class="bg-admin-surface-hover text-admin-text-muted text-xs font-semibold uppercase tracking-wider border-b border-admin-border">
              <th class="py-3 px-6">Produto</th>
              <th class="py-3 px-6">Categoria</th>
              <th class="py-3 px-6">Status</th>
              <th class="py-3 px-6 text-center">Destaque</th>
              <th class="py-3 px-6 text-right">Ações</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-admin-border">
            {products.map((p) => (
              <tr class="hover:bg-admin-surface-hover transition-colors group">
                <td class="py-3 px-6">
                  <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded border border-admin-border bg-admin-surface-hover flex items-center justify-center shrink-0">
                      <Package className="w-4 h-4 text-admin-text-muted" />
                    </div>
                    <div>
                      <p class="font-medium text-admin-text">{p.name}</p>
                      <p class="text-xs text-admin-text-muted font-mono">{p.id.slice(0, 8)}</p>
                    </div>
                  </div>
                </td>
                <td class="py-3 px-6">
                  <span class="px-2 py-0.5 text-xs rounded bg-admin-surface-hover border border-admin-border text-admin-text-muted">
                    {categoryLabels[p.category] || p.category}
                  </span>
                </td>
                <td class="py-3 px-6">
                  <Badge 
                    text={p.active ? 'Ativo' : 'Rascunho'} 
                    variant={p.active ? 'success' : 'neutral'} 
                    dot={true} 
                  />
                </td>
                <td class="py-3 px-6 text-center">
                  {p.featured ? <Star className="w-4 h-4 fill-amber-400 text-amber-400 mx-auto" /> : <span class="text-admin-text-muted text-xs">—</span>}
                </td>
                <td class="py-3 px-6">
                  <div class="flex items-center justify-end gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                    <button class="p-1.5 text-admin-text-muted hover:text-admin-text hover:bg-admin-surface-hover rounded transition-colors" aria-label="Editar">
                      <Edit className="w-4 h-4" />
                    </button>
                    <button class="p-1.5 text-admin-text-muted hover:text-admin-danger hover:bg-red-50 rounded transition-colors" aria-label="Excluir">
                      <Trash2 className="w-4 h-4" />
                    </button>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    ) : (
      <div class="p-16 flex flex-col items-center justify-center text-center">
        <Package className="w-10 h-10 text-admin-text-muted mb-4" />
        <h3 class="text-base font-semibold text-admin-text mb-1">Catálogo vazio</h3>
        <p class="text-sm text-admin-text-muted mb-6">
          {supabaseUrl ? 'Adicione o primeiro produto para exibição no site.' : 'Configure PUBLIC_SUPABASE_URL para começar.'}
        </p>
        <button disabled={!supabaseUrl} class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium bg-admin-accent text-white rounded-lg hover:bg-admin-accent-hover transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
          <Plus className="w-4 h-4" /> Adicionar Produto
        </button>
      </div>
    )}
  </div>

</AdminLayout>
