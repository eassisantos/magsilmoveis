---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { Package, Save, ArrowLeft } from 'lucide-react';
import { createSupabaseAdmin } from '../../../lib/supabase';

let errorMsg = '';
let successMsg = '';

if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const name = data.get('name') as string;
    const slug = data.get('slug') as string;
    const category = data.get('category') as string;
    const description = data.get('description') as string;
    const image_url = data.get('image_url') as string;
    const active = data.get('active') === 'on';
    const featured = data.get('featured') === 'on';

    if (!name || !slug || !category) {
      errorMsg = 'Nome, Slug e Categoria são obrigatórios.';
    } else {
      const supabase = createSupabaseAdmin();
      const { error } = await supabase.from('products').insert([
        { name, slug, category, description, image_url, active, featured }
      ]);
      
      if (error) {
        errorMsg = 'Erro ao salvar produto: ' + error.message;
      } else {
        return Astro.redirect('/admin/produtos?success=created');
      }
    }
  } catch (err: any) {
    errorMsg = err.message || 'Ocorreu um erro inesperado.';
  }
}
---

<AdminLayout title="Novo Produto" breadcrumb="Novo Produto">
  
  <div class="mb-6">
    <a href="/admin/produtos" class="inline-flex items-center gap-2 text-sm text-admin-text-muted hover:text-admin-text transition-colors">
      <ArrowLeft className="w-4 h-4" /> Voltar para lista
    </a>
  </div>

  <div class="max-w-2xl bg-admin-surface border border-admin-border rounded-lg overflow-hidden">
    <div class="px-6 py-4 border-b border-admin-border">
      <h2 class="text-sm font-semibold text-admin-text flex items-center gap-2">
        <Package className="w-4 h-4" /> Cadastrar Produto
      </h2>
    </div>

    <form method="POST" class="p-6 space-y-6">
      {errorMsg && (
        <div class="p-3 bg-red-50 text-red-600 text-sm rounded border border-red-100">
          {errorMsg}
        </div>
      )}

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-admin-text mb-1">Nome do Produto *</label>
          <input type="text" name="name" required class="w-full px-3 py-2 border border-admin-border rounded-md bg-admin-surface text-admin-text focus:outline-none focus:ring-1 focus:ring-admin-accent" placeholder="Ex: Poltrona Vega" />
        </div>
        <div>
          <label class="block text-sm font-medium text-admin-text mb-1">Slug (URL) *</label>
          <input type="text" name="slug" required class="w-full px-3 py-2 border border-admin-border rounded-md bg-admin-surface text-admin-text focus:outline-none focus:ring-1 focus:ring-admin-accent" placeholder="Ex: poltrona-vega" />
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium text-admin-text mb-1">Categoria *</label>
        <select name="category" required class="w-full px-3 py-2 border border-admin-border rounded-md bg-admin-surface text-admin-text focus:outline-none focus:ring-1 focus:ring-admin-accent">
          <option value="">Selecione...</option>
          <option value="poltronas">Poltronas</option>
          <option value="chaises">Chaises</option>
          <option value="mesas">Mesas & Cadeiras</option>
          <option value="area_externa">Área Externa</option>
          <option value="banquetas">Banquetas</option>
        </select>
      </div>

      <div>
        <label class="block text-sm font-medium text-admin-text mb-1">Descrição</label>
        <textarea name="description" rows="3" class="w-full px-3 py-2 border border-admin-border rounded-md bg-admin-surface text-admin-text focus:outline-none focus:ring-1 focus:ring-admin-accent" placeholder="Breve descrição do produto..."></textarea>
      </div>

      <div>
        <label class="block text-sm font-medium text-admin-text mb-1">URL da Imagem</label>
        <input type="url" name="image_url" class="w-full px-3 py-2 border border-admin-border rounded-md bg-admin-surface text-admin-text focus:outline-none focus:ring-1 focus:ring-admin-accent" placeholder="https://..." />
        <p class="text-xs text-admin-text-muted mt-1">Insira um link direto para a imagem (ex: Unsplash ou Imgur).</p>
      </div>

      <div class="flex gap-6">
        <label class="flex items-center gap-2 text-sm text-admin-text cursor-pointer">
          <input type="checkbox" name="active" checked class="rounded border-admin-border text-admin-accent focus:ring-admin-accent" />
          Produto Ativo (Visível)
        </label>
        <label class="flex items-center gap-2 text-sm text-admin-text cursor-pointer">
          <input type="checkbox" name="featured" class="rounded border-admin-border text-admin-accent focus:ring-admin-accent" />
          Destaque (Home)
        </label>
      </div>

      <div class="pt-4 border-t border-admin-border flex justify-end">
        <button type="submit" class="inline-flex items-center gap-2 px-6 py-2 text-sm font-medium bg-admin-accent text-white rounded-lg hover:bg-admin-accent-hover transition-colors">
          <Save className="w-4 h-4" /> Salvar Produto
        </button>
      </div>
    </form>
  </div>
</AdminLayout>
