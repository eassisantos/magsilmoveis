---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { FileText, Save, ArrowLeft } from 'lucide-react';
import { createSupabaseAdmin } from '../../../lib/supabase';

let errorMsg = '';

const BLOG_CATEGORIES = [
  'Design',
  'Decoração',
  'Área Externa',
  'Cuidados e Manutenção',
  'Tendências',
  'Projetos',
  'Inspiração',
];

if (Astro.request.method === 'POST') {
  try {
    const form = await Astro.request.formData();
    const title       = (form.get('title')        as string)?.trim();
    const slug        = (form.get('slug')          as string)?.trim();
    const excerpt     = (form.get('excerpt')       as string)?.trim();
    const content_html = (form.get('content_html') as string)?.trim();
    const image_url   = (form.get('image_url')     as string)?.trim();
    const category    = (form.get('category')      as string)?.trim();
    const tagsRaw     = (form.get('tags')          as string)?.trim();
    const status      = (form.get('status')        as string) || 'draft';

    if (!title || !slug || !content_html) {
      errorMsg = 'Título, Slug e Conteúdo são obrigatórios.';
    } else {
      const tags = tagsRaw
        ? tagsRaw.split(',').map((t) => t.trim()).filter(Boolean)
        : [];

      const payload: Record<string, unknown> = {
        title, slug, excerpt, content_html, image_url, category, tags, status,
      };
      if (status === 'published') {
        payload.published_at = new Date().toISOString();
      }

      const supabase = createSupabaseAdmin();
      const { error } = await supabase.from('blog_posts').insert([payload]);

      if (error) {
        errorMsg = 'Erro ao salvar post: ' + error.message;
      } else {
        return Astro.redirect('/admin/posts?success=created');
      }
    }
  } catch (err: unknown) {
    errorMsg = err instanceof Error ? err.message : 'Ocorreu um erro inesperado.';
  }
}

const inputClass = 'w-full px-3 py-2.5 border border-admin-border rounded-lg bg-admin-surface text-admin-text text-sm focus:outline-none focus:ring-2 focus:ring-admin-accent/40 focus:border-admin-accent transition-colors';
const labelClass = 'block text-sm font-medium text-admin-text mb-1.5';
---

<AdminLayout title="Novo Post" breadcrumb="Novo Post">

  <div class="mb-6">
    <a href="/admin/posts" class="inline-flex items-center gap-2 text-sm text-admin-text-muted hover:text-admin-text transition-colors">
      <ArrowLeft className="w-4 h-4" /> Voltar para lista
    </a>
  </div>

  <div class="max-w-4xl bg-admin-surface border border-admin-border rounded-xl overflow-hidden shadow-sm">

    <!-- Header -->
    <div class="px-6 py-4 border-b border-admin-border flex items-center justify-between bg-admin-surface-hover">
      <h2 class="text-sm font-semibold text-admin-text flex items-center gap-2">
        <FileText className="w-4 h-4 text-admin-accent" /> Novo Artigo
      </h2>
      <span class="text-xs text-admin-text-muted">* campos obrigatórios</span>
    </div>

    <form method="POST" class="p-6 space-y-6">

      {errorMsg && (
        <div class="p-3.5 bg-red-50 text-red-600 text-sm rounded-lg border border-red-200 flex items-start gap-2">
          <span class="mt-0.5">⚠</span>
          {errorMsg}
        </div>
      )}

      <!-- Título + Slug -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class={labelClass} for="post-title">Título do Post *</label>
          <input
            type="text"
            id="post-title"
            name="title"
            required
            class={inputClass}
          />
        </div>
        <div>
          <label class={labelClass} for="post-slug">
            Slug (URL) *
            <span class="text-[10px] font-normal text-admin-text-muted ml-1">— gerado automaticamente</span>
          </label>
          <input
            type="text"
            id="post-slug"
            name="slug"
            required
            class={`${inputClass} font-mono`}
          />
        </div>
      </div>

      <!-- Categoria + Status -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class={labelClass} for="post-category">Categoria *</label>
          <select id="post-category" name="category" required class={inputClass}>
            {BLOG_CATEGORIES.map((cat) => (
              <option value={cat}>{cat}</option>
            ))}
          </select>
        </div>
        <div>
          <label class={labelClass} for="post-status">Status de Publicação</label>
          <select id="post-status" name="status" class={inputClass}>
            <option value="draft">📝  Rascunho</option>
            <option value="published">✅  Publicado</option>
          </select>
        </div>
      </div>

      <!-- Excerpt -->
      <div>
        <label class={labelClass} for="post-excerpt">Resumo (Excerpt)</label>
        <textarea
          id="post-excerpt"
          name="excerpt"
          rows="2"
          class={inputClass}
          class={inputClass}
        ></textarea>
        <p class="text-xs text-admin-text-muted mt-1">Recomendado: até 160 caracteres para SEO.</p>
      </div>

      <!-- Conteúdo HTML -->
      <div>
        <label class={labelClass} for="post-content">Conteúdo HTML *</label>
        <textarea
          id="post-content"
          name="content_html"
          required
          rows="14"
          class={`${inputClass} font-mono text-xs leading-relaxed`}
          class={`${inputClass} font-mono text-xs leading-relaxed`}
        ></textarea>
        <p class="text-xs text-admin-text-muted mt-1">
          O conteúdo será sanitizado (DOMPurify) automaticamente antes de ser exibido.
        </p>
      </div>

      <!-- URL da imagem + Tags -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class={labelClass} for="post-image">URL da Imagem de Capa</label>
          <input
            type="url"
            id="post-image"
            name="image_url"
            class={inputClass}
            class={inputClass}
          />
          <p class="text-xs text-admin-text-muted mt-1">Proporção ideal: 16:9 (ex: 1600×900px).</p>
        </div>
        <div>
          <label class={labelClass} for="post-tags">Tags</label>
          <input
            type="text"
            id="post-tags"
            name="tags"
            class={inputClass}
            class={inputClass}
          />
          <p class="text-xs text-admin-text-muted mt-1">Separe as tags por vírgula.</p>
        </div>
      </div>

      <!-- Actions -->
      <div class="pt-5 border-t border-admin-border flex items-center justify-between gap-4">
        <a
          href="/admin/posts"
          class="inline-flex items-center gap-2 px-5 py-2.5 text-sm text-admin-text-muted border border-admin-border rounded-lg hover:bg-admin-surface-hover transition-colors"
        >
          Cancelar
        </a>
        <button
          type="submit"
          class="inline-flex items-center gap-2 px-6 py-2.5 text-sm font-medium bg-admin-accent text-white rounded-lg hover:bg-admin-accent-hover transition-colors shadow-sm"
        >
          <Save className="w-4 h-4" /> Salvar Post
        </button>
      </div>
    </form>
  </div>
</AdminLayout>

<!-- Auto-slug generator -->
<script>
  const titleInput  = document.getElementById('post-title')  as HTMLInputElement | null;
  const slugInput   = document.getElementById('post-slug')   as HTMLInputElement | null;
  let slugEdited = false;

  function toSlug(str: string): string {
    return str
      .toLowerCase()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '')  // remove diacritics
      .replace(/[^a-z0-9\s-]/g, '')
      .trim()
      .replace(/\s+/g, '-')
      .replace(/-+/g, '-');
  }

  titleInput?.addEventListener('input', () => {
    if (!slugEdited && slugInput) {
      slugInput.value = toSlug(titleInput.value);
    }
  });

  slugInput?.addEventListener('input', () => {
    slugEdited = slugInput.value.length > 0;
  });
</script>
