---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Mail, MapPin, Clock, Clock3, ShieldCheck, MessageCircle } from 'lucide-react';
import { business, whatsappLink } from '@/config/business';
import WhatsAppIcon from '../components/ui/icons/WhatsAppIcon.astro';

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://magsilmoveis.com.br';

const trustItems = [
  { icon: Clock3, label: 'Resposta em até 24h' },
  { icon: ShieldCheck, label: 'Sem compromisso' },
  { icon: MessageCircle, label: 'Orçamento gratuito' },
];
---

<BaseLayout
  title="Contato & Orçamento Personalizado"
  description="Solicite seu orçamento personalizado para móveis artesanais em fibra sintética e corda náutica. Atendemos projetos residenciais, comerciais e de arquitetura. Retornamos em até 24h."
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'LocalBusiness',
      '@id': `${siteUrl}/#localbusiness`,
      name: business.name,
      legalName: business.legalName,
      description: business.descriptionLong,
      url: siteUrl,
      telephone: business.phone.schema,
      email: business.email,
      priceRange: business.priceRange,
      foundingDate: business.foundingDate,
      address: {
        '@type': 'PostalAddress',
        streetAddress: business.address.street,
        addressLocality: business.address.city,
        addressRegion: business.address.state,
        postalCode: business.address.postalCode,
        addressCountry: business.address.country,
      },
      geo: {
        '@type': 'GeoCoordinates',
        latitude: business.address.geo.latitude,
        longitude: business.address.geo.longitude,
      },
      openingHoursSpecification: business.hours.schema,
      sameAs: [
        business.social.instagram,
        business.social.facebook,
        business.social.tiktok,
      ],
    })} />
  </Fragment>

  <!-- Hero -->
  <section class="section-padding-sm bg-surface">
    <div class="container-magsil">
      <nav aria-label="Localização" class="mb-6">
        <ol class="flex flex-wrap items-center gap-2 text-sm text-text-secondary" role="list">
          <li><a href="/" class="hover:text-gold transition-colors duration-base">Início</a></li>
          <li aria-hidden="true" class="text-gold/50 text-xs">•</li>
          <li class="text-text-primary font-medium" aria-current="page">Contato</li>
        </ol>
      </nav>
      <div class="text-center" data-animate>
        <span class="text-gold text-sm font-normal uppercase tracking-eyebrow-wide">Orçamento Personalizado</span>
        <h1 class="mt-4 mb-4">Seu projeto merece<br class="hidden md:block" /> uma peça única.</h1>
        <p class="text-text-secondary max-w-xl mx-auto leading-relaxed">
          Conte-nos sua ideia — ambiente, estilo, materiais. Nossa equipe monta uma proposta sob medida e retorna em até 24 horas.
        </p>
        <div class="w-16 h-0.5 bg-gold mx-auto mt-6"></div>
      </div>
    </div>
  </section>

  <section class="section-padding bg-offwhite">
    <div class="container-magsil">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">

        <!-- Form -->
        <div class="lg:col-span-3" data-animate>
          <form id="contact-form" class="bg-surface rounded-[var(--radius-lg)] p-8 border border-border-light">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
              <div>
                <label for="name" class="block text-sm font-normal text-text-primary mb-2">Nome completo *</label>
                <input type="text" id="name" name="name" required minlength="2" maxlength="100" class="w-full min-h-[48px] px-4 bg-offwhite border border-border rounded-[var(--radius-md)] text-text-primary text-base focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition-all" />
              </div>
              <div>
                <label for="email" class="block text-sm font-normal text-text-primary mb-2">E-mail *</label>
                <input type="email" id="email" name="email" required maxlength="255" class="w-full min-h-[48px] px-4 bg-offwhite border border-border rounded-[var(--radius-md)] text-text-primary text-base focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition-all" />
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
              <div>
                <label for="phone" class="block text-sm font-normal text-text-primary mb-2">Telefone / WhatsApp</label>
                <input type="tel" id="phone" name="phone" maxlength="20" class="w-full min-h-[48px] px-4 bg-offwhite border border-border rounded-[var(--radius-md)] text-text-primary text-base focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition-all" />
              </div>
              <div>
                <label for="projectType" class="block text-sm font-normal text-text-primary mb-2">Tipo de projeto</label>
                <select id="projectType" name="projectType" class="w-full min-h-[48px] px-4 bg-offwhite border border-border rounded-[var(--radius-md)] text-text-primary text-base focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition-all">
                  <option value="">Selecione</option>
                  <option value="residencial">Residencial</option>
                  <option value="comercial">Comercial</option>
                  <option value="corporativo">Corporativo</option>
                  <option value="arquitetura">Projeto de Arquitetura</option>
                  <option value="outro">Outro</option>
                </select>
              </div>
            </div>

            <div class="mb-6">
              <label for="message" class="block text-sm font-normal text-text-primary mb-2">Mensagem *</label>
              <textarea id="message" name="message" required minlength="10" maxlength="2000" rows="5" class="w-full px-4 py-3 bg-offwhite border border-border rounded-[var(--radius-md)] text-text-primary text-base focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition-all resize-y"></textarea>
            </div>

            <!-- Trust strip -->
            <div class="flex flex-wrap gap-4 mb-6 py-4 border-y border-border-light/60">
              {trustItems.map(({ icon: Icon, label }) => (
                <div class="flex items-center gap-2 text-xs text-text-secondary">
                  <Icon className="w-3.5 h-3.5 text-gold" aria-hidden="true" strokeWidth={2} />
                  <span>{label}</span>
                </div>
              ))}
            </div>

            <!-- Status messages -->
            <div id="form-status" class="mb-6 hidden" role="status" aria-live="polite" aria-atomic="true">
              <div id="form-success" class="hidden p-4 bg-success/10 border border-success/30 rounded-[var(--radius-md)] text-success text-sm">
                ✓ Mensagem enviada com sucesso! Retornaremos em breve.
              </div>
              <div id="form-error" class="hidden p-4 bg-error/10 border border-error/30 rounded-[var(--radius-md)] text-error text-sm">
                ✗ Erro ao enviar mensagem. Tente novamente ou entre em contato pelo WhatsApp.
              </div>
            </div>

            <button type="submit" id="form-submit" class="w-full md:w-auto inline-flex items-center justify-center gap-2 min-h-[52px] px-8 bg-gold text-anthracite text-base font-normal rounded-[var(--radius-md)] hover:bg-gold-light transition-all duration-base disabled:opacity-50 disabled:cursor-not-allowed shadow-gold">
              Solicitar Meu Orçamento →
            </button>
          </form>

          <!-- WhatsApp fast-track -->
          <div class="mt-4 flex items-center gap-4">
            <div class="flex-1 h-px bg-border-light"></div>
            <span class="text-xs text-text-muted uppercase tracking-widest">ou</span>
            <div class="flex-1 h-px bg-border-light"></div>
          </div>
          <a
            href={whatsappLink('Olá! Vim pelo site e gostaria de solicitar um orçamento.')}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-4 flex items-center justify-center gap-3 w-full min-h-[52px] bg-[#25D366] hover:bg-[#1ebe5d] text-white text-base font-normal rounded-[var(--radius-md)] transition-all duration-base"
            aria-label="Falar agora pelo WhatsApp (abre em nova aba)"
          >
            <WhatsAppIcon class="w-5 h-5" aria-hidden="true" />
            Prefere falar agora? Resposta imediata pelo WhatsApp
          </a>
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-2" data-animate data-animate-delay="2">
          <div class="space-y-6">

            <!-- Mini depoimento -->
            <div class="bg-anthracite rounded-[var(--radius-lg)] p-6 border border-border-light">
              <div class="flex gap-1 mb-3" aria-label="5 estrelas">
                {Array.from({ length: 5 }).map(() => (
                  <svg class="w-4 h-4 text-gold fill-current" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                ))}
              </div>
              <blockquote>
                <p class="text-offwhite/90 text-sm leading-relaxed italic">
                  "O acabamento das peças é impecável. Compramos um conjunto para nossa varanda e já recebemos muitos elogios dos convidados."
                </p>
              </blockquote>
              <footer class="mt-4 flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-gold/20 flex items-center justify-center flex-shrink-0">
                  <span class="text-gold text-xs font-medium">CM</span>
                </div>
                <div>
                  <p class="text-offwhite text-sm font-normal">Cristiano Moreira</p>
                  <p class="text-text-muted text-xs">Cliente • Google</p>
                </div>
              </footer>
            </div>

            <!-- Informações de contato -->
            <div class="bg-surface rounded-[var(--radius-lg)] p-6 border border-border-light">
              <h3 class="text-base font-normal text-text-primary mb-5">Informações de Contato</h3>
              <ul class="space-y-4">
                <li>
                  <a
                    href={whatsappLink()}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-start gap-3 text-text-secondary hover:text-gold transition-colors min-h-[48px]"
                    aria-label="Falar pelo WhatsApp (abre em nova aba)"
                  >
                    <WhatsAppIcon class="w-5 h-5 mt-0.5 flex-shrink-0" aria-hidden="true" />
                    <div>
                      <p class="font-normal text-text-primary text-sm">WhatsApp</p>
                      <p class="text-sm">{business.phone.formatted}</p>
                    </div>
                  </a>
                </li>
                <li>
                  <a
                    href={`mailto:${business.email}`}
                    class="flex items-start gap-3 text-text-secondary hover:text-gold transition-colors min-h-[48px]"
                    aria-label={`Enviar e-mail para ${business.email}`}
                  >
                    <Mail className="w-5 h-5 mt-0.5 flex-shrink-0" aria-hidden="true" />
                    <div>
                      <p class="font-normal text-text-primary text-sm">E-mail</p>
                      <p class="text-sm">{business.email}</p>
                    </div>
                  </a>
                </li>
                <li class="flex items-start gap-3 text-text-secondary min-h-[48px]">
                  <MapPin className="w-5 h-5 mt-0.5 flex-shrink-0" aria-hidden="true" />
                  <div>
                    <p class="font-normal text-text-primary text-sm">Endereço</p>
                    <address class="not-italic text-sm">
                      {business.address.street}, {business.address.neighborhood}<br/>
                      {business.address.city} — {business.address.state}
                    </address>
                  </div>
                </li>
                <li class="flex items-start gap-3 text-text-secondary min-h-[48px]">
                  <Clock className="w-5 h-5 mt-0.5 flex-shrink-0" aria-hidden="true" />
                  <div>
                    <p class="font-normal text-text-primary text-sm">Horário</p>
                    <p class="whitespace-pre-line text-sm">{business.hours.display}</p>
                  </div>
                </li>
              </ul>
            </div>

          </div>
        </div>

      </div>
    </div>
  </section>

  <script src="../scripts/contact.ts"></script>
</BaseLayout>
