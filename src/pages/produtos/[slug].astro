---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';
import { createSupabaseServerClient } from '../../lib/supabase';
import { CheckCircle2, Shield, Truck, Package, ChevronRight, Star, ArrowRight } from 'lucide-react';
import { business, whatsappLink } from '../../config/business';

const { slug } = Astro.params;

let product = null;
try {
  const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);
  const { data, error } = await supabase
    .from('products')
    .select('name, description, category, image_url')
    .eq('slug', slug)
    .eq('active', true)
    .single();
    
  if (data) {
    product = {
      ...data,
      image: data.image_url || 'https://images.unsplash.com/photo-1567538096630-e0c55bd6374c?auto=format&fit=crop&w=800&q=80',
      images: [data.image_url || 'https://images.unsplash.com/photo-1567538096630-e0c55bd6374c?auto=format&fit=crop&w=800&q=80'],
      features: ['Personalizável em cores e medidas', 'Fabricação artesanal de alto padrão', 'Resistente a intempéries e raios UV', 'Estrutura em alumínio reforçado'],
      benefits: data.description,
      specs: {}
    };
  }
} catch (e) {
  console.error('Error fetching product:', e);
}

if (!product) {
  return Astro.redirect('/404');
}

const wppMsg = `Olá! Gostaria de saber mais sobre o produto *${product.name}* que vi no site.`;
const wppUrl = whatsappLink(wppMsg);

---

<BaseLayout
  title={`${product.name} | Catálogo Magsil Móveis`}
  description={product.description || `Confira os detalhes de ${product.name} da Magsil Móveis. Fabricação própria, alto padrão e personalização total.`}
>
  <section class="section-padding bg-surface pt-24 lg:pt-32">
    <div class="container-magsil">
      <!-- Breadcrumbs -->
      <nav aria-label="Localização" class="mb-8" data-animate>
        <ol class="flex flex-wrap items-center gap-2 text-sm text-text-secondary" role="list">
          <li><a href="/" class="hover:text-gold transition-colors">Início</a></li>
          <li aria-hidden="true" class="text-gold/50">•</li>
          <li><a href="/catalogo" class="hover:text-gold transition-colors">Catálogo</a></li>
          <li aria-hidden="true" class="text-gold/50">•</li>
          <li class="text-text-primary font-medium" aria-current="page">{product.name}</li>
        </ol>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
        <!-- Image -->
        <div class="rounded-[var(--radius-lg)] overflow-hidden bg-offwhite border border-border-light aspect-[4/3] lg:aspect-auto lg:h-[600px] shadow-sm" data-animate>
          <img src={product.image} alt={product.name} class="w-full h-full object-cover" />
        </div>

        <!-- Details -->
        <div class="flex flex-col justify-center" data-animate data-animate-delay="1">
          <span class="text-xs font-medium uppercase tracking-[0.2em] text-gold mb-3 block">
            {product.category.replace('_', ' ')}
          </span>
          <h1 class="text-3xl lg:text-4xl mb-6">{product.name}</h1>
          <div class="w-16 h-0.5 bg-gold mb-8"></div>
          
          <div class="prose prose-magsil max-w-none text-text-secondary mb-10">
            <p class="text-lg leading-relaxed">{product.description}</p>
          </div>

          <div class="space-y-4 mb-10">
            {product.features.map((feat: string) => (
              <div class="flex items-start gap-3">
                <div class="mt-1 min-w-[24px] h-6 flex items-center justify-center rounded-full bg-gold/10 text-gold">
                  <CheckCircle2 className="w-3.5 h-3.5" />
                </div>
                <p class="text-text-primary">{feat}</p>
              </div>
            ))}
          </div>

          <div class="flex flex-col sm:flex-row gap-4 mt-auto">
            <a 
              href={wppUrl} 
              target="_blank" 
              rel="noopener noreferrer" 
              class="inline-flex items-center justify-center min-h-[52px] px-8 bg-anthracite text-offwhite text-base font-normal rounded-[var(--radius-md)] hover:bg-gold transition-colors duration-base shadow-sm"
            >
              Solicitar Orçamento
            </a>
            <a 
              href="/catalogo" 
              class="inline-flex items-center justify-center min-h-[52px] px-8 bg-transparent border border-border-light text-text-primary text-base font-normal rounded-[var(--radius-md)] hover:border-gold hover:text-gold transition-colors duration-base"
            >
              Voltar ao Catálogo
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
