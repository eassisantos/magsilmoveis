---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { CheckCircle2, Shield, Truck, Package, ChevronRight, Star, ArrowRight } from 'lucide-react';

export function getStaticPaths() {
  const products = [
    {
      slug: 'poltrona-vega',
      name: 'Poltrona Vega',
      category: 'Poltronas',
      description: 'Uma obra-prima do design contemporâneo. A Poltrona Vega combina estrutura robusta com uma trama artesanal em corda náutica, oferecendo o equilíbrio perfeito entre conforto ergonômico e sofisticação visual para ambientes internos e externos cobertos.',
      price: 'R$ 2.490,00',
      installments: 'ou 10x de R$ 249,00 sem juros',
      features: ['Estrutura em alumínio reforçado', 'Corda náutica com proteção UV', 'Estofamento de alta densidade', 'Acabamento premium artesanal', 'Garantia estrutural de 2 anos', 'Resistente a intempéries'],
