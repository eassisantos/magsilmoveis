---
import BlogLayout from '../../layouts/BlogLayout.astro';
import PortableText from '../../components/PortableText.astro';
import { getAllBlogSlugs, urlFor, blocksToPlainText, type SanityBlogPost } from '../../lib/sanity';
import { loadQuery } from '../../sanity/lib/load-query';
import { BLOG_POST_BY_SLUG_QUERY, RELATED_BLOG_POSTS_QUERY } from '../../sanity/lib/queries';

export async function getStaticPaths() {
  const slugs = await getAllBlogSlugs().catch(() => []);
  return slugs.map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;

const { data: post } = await loadQuery<SanityBlogPost>({
  query: BLOG_POST_BY_SLUG_QUERY,
  params: { slug },
}).catch(() => ({ data: null }));

if (!post) {
  return Astro.redirect('/404');
}

const { data: relatedPosts } = post.category
  ? await loadQuery<SanityBlogPost[]>({
      query: RELATED_BLOG_POSTS_QUERY,
      params: { slug: post.slug, category: post.category, limit: 3 },
    }).catch(() => ({ data: [] as SanityBlogPost[] }))
  : { data: [] as SanityBlogPost[] };

const tags: string[] = post.tags ?? [];

const coverImageUrl = post.mainImage
  ? urlFor(post.mainImage).width(1200).height(630).auto('format').quality(85).url()
  : undefined;

function calcReadingTime(blocks: any[] | undefined): number {
  const text = blocksToPlainText(blocks ?? []);
  const words = text.trim().split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.ceil(words / 200));
}

const readingTime = post.readingTimeMinutes ?? calcReadingTime(post.content);

// Normalizar related posts para o contrato do BlogLayout
const relatedForLayout = relatedPosts.map(r => ({
  slug: r.slug,
  title: r.title,
  excerpt: r.excerpt ?? undefined,
  image_url: r.mainImage ? urlFor(r.mainImage).width(400).height(225).auto('format').quality(75).url() : undefined,
  published_at: r.publishedAt ?? undefined,
  category: r.category ?? undefined,
}));
---

<BlogLayout
  title={post.seo?.metaTitle ?? post.title}
  description={post.seo?.metaDescription ?? post.excerpt}
  pubDate={post.publishedAt ? new Date(post.publishedAt) : undefined}
  coverImage={coverImageUrl}
  author="Magsil Móveis"
  category={post.category ?? 'Design'}
  tags={tags}
  readingTime={readingTime}
  relatedPosts={relatedForLayout}
>
  {post.content?.length
    ? <PortableText value={post.content} />
    : <p class="text-stone-500 italic">Conteúdo em breve.</p>
  }
</BlogLayout>
