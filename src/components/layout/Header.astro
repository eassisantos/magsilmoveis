---
import { Menu, X, Phone } from 'lucide-react';
import Logo from '../ui/Logo.astro';
import InstagramIcon from '../ui/icons/InstagramIcon.astro';
import FacebookIcon from '../ui/icons/FacebookIcon.astro';
import TikTokIcon from '../ui/icons/TikTokIcon.astro';
import { business, whatsappLink, whatsappMessages } from '../../config/business';

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);

const navLinks = [
  { href: '/',         label: 'Início'   },
  { href: '/sobre',    label: 'Sobre'    },
  { href: '/catalogo', label: 'Catálogo' },
  { href: '/blog',     label: 'Blog'     },
  { href: '/contato',  label: 'Contato'  },
];

const whatsappQuoteUrl = whatsappLink(whatsappMessages.quote);
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-[var(--z-sticky)]"
>
  <!-- ── Ribbon utilitário (desktop) ── -->
  <div id="top-ribbon" class="hidden md:block bg-anthracite transition-all duration-300 overflow-hidden">
    <div class="container-magsil">
      <div class="flex items-center justify-between h-8 text-[11px] text-text-on-dark">
        <div class="flex items-center gap-5">
          <a
            href={business.phone.tel}
            class="flex items-center gap-1.5 hover:text-gold-light transition-colors duration-base"
            aria-label={`Ligar: ${business.phone.formatted}`}
          >
            <Phone className="w-3 h-3 flex-shrink-0" aria-hidden="true" />
            {business.phone.formatted}
          </a>
          <a
            href={`mailto:${business.email}`}
            class="flex items-center gap-1.5 hover:text-gold-light transition-colors duration-base"
          >
            {business.email}
          </a>
        </div>
        <!-- Redes sociais -->
        <div class="flex items-center gap-3" aria-label="Redes sociais">
          <a
            href={business.social.instagram}
            target="_blank"
            rel="noopener noreferrer"
            class="text-text-on-dark hover:text-gold transition-colors duration-base flex items-center"
            aria-label="Instagram (abre em nova aba)"
          >
            <InstagramIcon class="w-3.5 h-3.5" aria-hidden="true" />
          </a>
          <a
            href={business.social.facebook}
            target="_blank"
            rel="noopener noreferrer"
            class="text-text-on-dark hover:text-gold transition-colors duration-base flex items-center"
            aria-label="Facebook (abre em nova aba)"
          >
            <FacebookIcon class="w-3.5 h-3.5" aria-hidden="true" />
          </a>
          <a
            href={business.social.tiktok}
            target="_blank"
            rel="noopener noreferrer"
            class="text-text-on-dark hover:text-gold transition-colors duration-base flex items-center"
            aria-label="TikTok (abre em nova aba)"
          >
            <TikTokIcon class="w-3.5 h-3.5" aria-hidden="true" />
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Barra de navegação principal (clara) ── -->
  <div class="bg-offwhite border-b border-border-light transition-all duration-300" id="main-navbar">
    <div class="container-magsil">
      <nav class="flex items-center justify-between h-20 transition-all duration-300" id="main-nav-content" aria-label="Navegação principal">

        <!-- Logo -->
        <a href="/" class="flex items-center gap-2.5 group flex-shrink-0 focus-ring rounded-[var(--radius-sm)]" aria-label={`${business.name} - Página inicial`}>
          <Logo theme="light" class="h-10 transition-transform duration-300 group-hover:scale-105 origin-left" />
        </a>

        <!-- Links desktop -->
        <div class="hidden lg:flex items-center gap-6 xl:gap-8">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class:list={[
                "group text-sm font-normal flex items-center min-h-[48px] transition-colors duration-300",
                isActive(link.href)
                  ? "text-gold"
                  : "text-text-secondary hover:text-anthracite"
              ]}
              aria-current={isActive(link.href) ? 'page' : undefined}
            >
              <span class="relative py-0.5">
                {link.label}
                <span class:list={[
                  "absolute bottom-0 left-0 w-full h-[2px] bg-gold origin-left transition-transform duration-300",
                  isActive(link.href) ? "scale-x-100" : "scale-x-0 group-hover:scale-x-100"
                ]}></span>
              </span>
            </a>
          ))}
        </div>

        <!-- CTA + botão mobile -->
        <div class="flex items-center gap-4">
          <a
            href="/contato"
            class="hidden lg:inline-flex items-center justify-center min-h-[48px] px-6 bg-anthracite hover:bg-gold text-text-inverse text-sm font-normal tracking-wide rounded-[var(--radius-md)] transition-all duration-300 shadow-sm hover:shadow-md hover:-translate-y-0.5"
          >
            Solicitar Orçamento
          </a>
          <button
            id="mobile-menu-toggle"
            type="button"
            class="lg:hidden min-h-[48px] min-w-[48px] flex items-center justify-center text-anthracite hover:text-gold transition-colors duration-300 focus-ring rounded-[var(--radius-sm)]"
            aria-label="Abrir menu de navegação"
            aria-expanded="false"
            aria-controls="mobile-menu"
          >
            <Menu className="w-6 h-6" aria-hidden="true" />
          </button>
        </div>

      </nav>
    </div>
  </div>

  <!-- ── Menu Mobile (claro) ── -->
  <div
    id="mobile-menu"
    class="lg:hidden fixed inset-0 z-[var(--z-modal)] bg-offwhite transform translate-x-full transition-transform duration-base ease-out"
    role="dialog"
    aria-modal="true"
    aria-label="Menu de navegação"
  >
    <div class="flex flex-col h-full">

      <!-- Cabeçalho mobile -->
      <div class="flex items-center justify-between h-16 px-6 border-b border-border-light bg-offwhite shadow-sm">
        <a href="/" class="focus-ring rounded-[var(--radius-sm)]" aria-label={`${business.name} - Página inicial`}>
          <Logo theme="light" class="h-8 origin-left" />
        </a>
        <button
          id="mobile-menu-close"
          type="button"
          class="min-h-[48px] min-w-[48px] flex items-center justify-center text-anthracite hover:text-gold hover:bg-gold/10 rounded-full transition-colors duration-300"
          aria-label="Fechar menu"
        >
          <X className="w-5 h-5" aria-hidden="true" />
        </button>
      </div>

      <!-- Links mobile -->
      <nav class="flex flex-col px-4 pt-4 space-y-1" aria-label="Menu mobile">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              "text-lg font-normal min-h-[56px] flex items-center px-4 rounded-[var(--radius-md)] transition-colors duration-300",
              isActive(link.href)
                ? "text-gold bg-gold/10"
                : "text-anthracite hover:text-gold hover:bg-gold/5"
            ]}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Rodapé mobile -->
      <div class="mt-auto px-6 pb-8 pt-6 space-y-4 bg-offwhite">
        <a
          href="/contato"
          class="w-full flex items-center justify-center min-h-[56px] px-6 bg-anthracite hover:bg-gold text-text-inverse text-lg font-normal tracking-wide rounded-[var(--radius-md)] transition-all duration-300 shadow-md shadow-anthracite/20"
        >
          Solicitar Orçamento
        </a>
        <a
          href={whatsappQuoteUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="w-full flex items-center justify-center min-h-[56px] px-6 border-2 border-border text-anthracite text-base font-normal rounded-[var(--radius-md)] hover:border-gold hover:text-gold transition-all duration-300"
        >
          WhatsApp: {business.phone.formatted}
        </a>
        <a
          href={business.phone.tel}
          class="w-full flex items-center justify-center gap-2 min-h-[48px] px-6 text-text-muted text-sm rounded-[var(--radius-md)] hover:text-gold transition-colors duration-300"
          aria-label={`Ligar: ${business.phone.formatted}`}
        >
          <Phone className="w-4 h-4" aria-hidden="true" />
          {business.phone.formatted}
        </a>
      </div>

    </div>
  </div>

</header>

<script src="../../scripts/header.ts"></script>