---
/**
 * PortableText.astro
 *
 * Componente central para renderizar Portable Text do Sanity
 * usando `astro-portabletext` — renderizador nativo (zero React).
 *
 * Registra o componente PortableTextImage para blocos de imagem
 * embutidos no conteúdo rico.
 */
import { PortableText as PT } from 'astro-portabletext'
import type { PortableTextBlock } from '@portabletext/types'
import PortableTextImage from './PortableTextImage.astro'

interface Props {
  value: PortableTextBlock[]
}

const { value } = Astro.props

const components = {
  type: {
    image: PortableTextImage,
  },
}
---

<div class="prose prose-stone max-w-none
  prose-headings:font-serif prose-headings:text-stone-900
  prose-p:text-stone-700 prose-p:leading-relaxed
  prose-a:text-amber-700 prose-a:underline hover:prose-a:text-amber-900
  prose-blockquote:border-l-amber-400 prose-blockquote:text-stone-500
  prose-strong:text-stone-900
  prose-code:bg-stone-100 prose-code:px-1 prose-code:rounded
  prose-img:rounded-lg">
  <PT value={value} components={components} />
</div>
