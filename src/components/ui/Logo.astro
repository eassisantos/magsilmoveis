---
interface Props {
  class?: string;
  theme?: 'dark' | 'light';
}

const { class: className, theme = 'light' } = Astro.props;
const textPrimary = theme === 'dark' ? 'text-text-inverse' : 'text-anthracite';
---

<div class:list={["flex items-center justify-start group", className]}>
  <img 
    src="/images/logo.png" 
    alt="Magsil Móveis" 
    class:list={[
      "w-auto h-full object-contain transition-transform duration-base group-hover:scale-[1.02]",
      theme === 'dark' ? 'brightness-0 invert opacity-90' : ''
    ]}
    loading="eager"
  />
</div>
