---
import { Star, ChevronLeft, ChevronRight } from 'lucide-react';
import GoogleIcon from '../ui/icons/GoogleIcon.astro';
import InstagramIcon from '../ui/icons/InstagramIcon.astro';
import { getActiveTestimonials } from '../../lib/sanity';

// Fallback estático caso Sanity não esteja configurado ainda
const fallbackTestimonials = [
  { _id: '1', name: 'Cindy Maciel', source: 'Google', content: 'Ótimo atendimento, produtos de excelente qualidade. Comprei móveis para minha residência e amei.', rating: 5 },
  { _id: '2', name: 'Ewersson Assis', source: 'Google', content: 'O atendimento é bom, os produtos são ótimos e entregam super rápido.', rating: 5 },
  { _id: '3', name: 'Neusene Nobre', source: 'Google', content: 'Gostei muito. Uma perfeição. Recomendo a todos que buscam qualidade e bom gosto em móveis para área externa.', rating: 5 },
  { _id: '4', name: 'Cristiano Moreira', source: 'Google', content: 'Ótimo atendimento e móveis de altíssima qualidade. O acabamento das peças é impecável.', rating: 5 },
  { _id: '5', name: 'Gilberto Vital', source: 'Google', content: 'Móveis artesanais lindíssimos. O cuidado no trançado da corda náutica é perceptível em cada detalhe.', rating: 5 },
  { _id: '6', name: 'Cliente via Instagram', source: 'Instagram', content: 'Estou muito contente com meu jogo, pelo conforto, pela elegância, por ser discreto e belo.', rating: 5 },
];

const testimonials = await getActiveTestimonials().catch(() => fallbackTestimonials);
const displayTestimonials = testimonials.length > 0 ? testimonials : fallbackTestimonials;
---
<section id="depoimentos" class="section-padding bg-surface overflow-hidden">
  <div class="container-magsil">
    <div class="flex flex-col md:flex-row items-start md:items-end justify-between mb-12 gap-6" data-animate>
      <div>
        <span class="text-gold text-sm font-normal uppercase tracking-[0.2em] block mb-3">Avaliações Reais</span>
        <h2 class="text-balance">O Que Nossos Clientes Dizem</h2>
      </div>
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-3">
        <!-- Google badge -->
        <div class="flex items-center gap-2 bg-offwhite px-4 py-2 rounded-[var(--radius-md)] border border-border-light shadow-sm">
          <GoogleIcon class="w-5 h-5" aria-hidden="true" />
          <div class="flex flex-col">
            <div class="flex items-center gap-1">
              <span class="text-sm font-normal">5.0</span>
              <div class="flex">
                {Array.from({ length: 5 }).map(() => (
                  <Star className="w-3 h-3 text-[#fbbc04] fill-current" aria-hidden="true" />
                ))}
              </div>
            </div>
            <span class="text-[0.65rem] text-text-muted">Avaliações no Google</span>
          </div>
        </div>
        
        <!-- Carousel Controls -->
        <div class="hidden md:flex items-center gap-2">
          <button id="testimonial-prev" class="w-10 h-10 flex items-center justify-center rounded-full bg-offwhite border border-border-light text-text-primary hover:text-gold hover:border-gold transition-colors duration-base shadow-sm focus-ring" aria-label="Depoimento anterior">
            <ChevronLeft className="w-5 h-5" aria-hidden="true" />
          </button>
          <button id="testimonial-next" class="w-10 h-10 flex items-center justify-center rounded-full bg-offwhite border border-border-light text-text-primary hover:text-gold hover:border-gold transition-colors duration-base shadow-sm focus-ring" aria-label="Próximo depoimento">
            <ChevronRight className="w-5 h-5" aria-hidden="true" />
          </button>
        </div>
      </div>
    </div>

    <!-- Carousel Container -->
    <div class="relative -mx-4 px-4 md:mx-0 md:px-0">
      <div id="testimonial-track" class="flex gap-6 md:gap-8 transition-transform duration-500 ease-out cursor-grab active:cursor-grabbing w-full overflow-hidden" data-animate data-animate-delay="1">
        {displayTestimonials.map((test) => (
          <div class="w-[85vw] sm:w-[50vw] md:w-[calc(33.333%-1.33rem)] flex-shrink-0">
            <div class="bg-offwhite rounded-[var(--radius-lg)] p-8 border border-border-light h-full flex flex-col shadow-sm">
              <div class="flex items-center justify-between mb-6">
                <div class="flex gap-1" aria-label={`${test.rating} estrelas`}>
                  {Array.from({ length: test.rating }).map(() => (
                    <Star className="w-4 h-4 text-gold fill-current" aria-hidden="true" />
                  ))}
                </div>
                {test.source === 'Google' ? (
                  <GoogleIcon class="w-5 h-5 opacity-70" aria-hidden="true" />
                ) : (
                  <InstagramIcon class="w-5 h-5 text-text-muted" aria-hidden="true" />
                )}
              </div>
              <blockquote class="flex-grow">
                <p class="text-text-secondary text-sm md:text-base leading-relaxed mb-6 italic hover-gold">
                  "{test.content}"
                </p>
              </blockquote>
              <div class="mt-auto">
                <p class="text-base font-normal text-text-primary">{test.name}</p>
                <p class="text-xs text-text-muted mt-1 uppercase tracking-widest">{test.source}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Dots indicator -->
    <div id="testimonial-dots" class="flex justify-center gap-2 mt-8">
      {Array.from({ length: Math.ceil(displayTestimonials.length / 1) }).map((_, i) => (
        <button 
          class="testimonial-dot relative w-2.5 h-2.5 rounded-full bg-border transition-colors duration-base before:content-[''] before:absolute before:w-12 before:h-12 before:-top-[19px] before:-left-[19px] before:rounded-full" 
          data-index={String(i)}
          aria-label={`Ir para página ${i + 1}`}
        ></button>
      ))}
    </div>
  </div>
</section>

<script src="../../scripts/testimonials.ts"></script>
