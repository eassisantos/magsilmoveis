---
import { createSupabaseServerClient } from '../../lib/supabase';
import { ArrowRight } from 'lucide-react';

let latestPosts: any[] = [];
try {
  const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);
  const { data } = await supabase
    .from('blog_posts')
    .select('slug, title, excerpt, image_url, published_at')
    .eq('status', 'published')
    .order('published_at', { ascending: false })
    .limit(3);
  if (data) latestPosts = data;
} catch (e) {
  // silently fail — section simply won't render
}

function formatDate(dateStr: string): string {
  if (!dateStr) return '';
  return new Date(dateStr).toLocaleDateString('pt-BR', {
    day: '2-digit', month: 'long', year: 'numeric',
  });
}
---
{latestPosts.length > 0 && (
  <section class="section-padding bg-surface">
    <div class="container-magsil">
      <div class="flex flex-col md:flex-row items-start md:items-center justify-between mb-12 gap-4" data-animate>
        <div>
          <span class="text-gold text-sm font-normal uppercase tracking-[0.2em]">Blog</span>
          <h2 class="mt-4">Dicas &amp; Inspirações</h2>
        </div>
        <a
          href="/blog"
          class="inline-flex items-center gap-2 text-sm font-normal text-gold hover:gap-3 transition-all duration-base min-h-[48px]"
        >
          Ver todos os artigos
          <ArrowRight className="w-4 h-4" aria-hidden="true" />
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {latestPosts.map((post, i) => (
          <a
            href={`/blog/${post.slug}`}
            class="group bg-offwhite rounded-[var(--radius-lg)] overflow-hidden border border-border-light hover-lift"
            data-animate
            data-animate-delay={String(i + 1)}
          >
            <div class="aspect-[16/9] bg-surface overflow-hidden">
              {post.image_url ? (
                <img
                  src={post.image_url}
                  alt={post.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-slow"
                  loading="lazy"
                />
              ) : (
                <img
                  src="/images/blog-fallback.png"
                  alt={post.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-slow"
                  loading="lazy"
                />
              )}
            </div>
            <div class="p-6">
              <span class="text-xs font-normal uppercase tracking-widest text-gold">Design</span>
              <h3 class="text-lg mt-2 mb-3 group-hover:text-gold transition-colors duration-base">{post.title}</h3>
              <p class="text-text-secondary text-sm leading-relaxed line-clamp-2">{post.excerpt}</p>
              <time class="block mt-4 text-xs text-text-muted" datetime={post.published_at}>
                {formatDate(post.published_at)}
              </time>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

