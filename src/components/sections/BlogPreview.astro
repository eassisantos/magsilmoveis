---
import { getCollection } from 'astro:content';
import { ArrowRight } from 'lucide-react';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

function formatDate(date: Date): string {
  return date.toLocaleDateString('pt-BR', {
    day: '2-digit',
    month: 'long',
    year: 'numeric',
  });
}
---
{latestPosts.length > 0 ? (
  <section class="section-padding bg-surface">
    <div class="container-magsil">
      <div class="flex flex-col md:flex-row items-start md:items-center justify-between mb-12 gap-4" data-animate>
        <div>
          <span class="text-gold text-sm font-normal uppercase tracking-[0.2em]">Blog</span>
          <h2 class="mt-4">Dicas & Inspirações</h2>
        </div>
        <a
          href="/blog"
          class="inline-flex items-center gap-2 text-sm font-normal text-gold hover:gap-3 transition-all duration-base min-h-[48px]"
        >
          Ver todos os artigos
          <ArrowRight className="w-4 h-4" aria-hidden="true" />
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {latestPosts.map((post, i) => (
          <a
            href={`/blog/${post.id}`}
            class="group bg-offwhite rounded-[var(--radius-lg)] overflow-hidden border border-border-light hover-lift"
            data-animate
            data-animate-delay={String(i + 1)}
          >
            <div class="aspect-[16/9] bg-surface overflow-hidden">
              {post.data.coverImage ? (
                <img
                  src={post.data.coverImage}
                  alt={post.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-slow"
                  loading="lazy"
                />
              ) : (
                <img src="/images/blog-placeholder.png" alt="Capa do artigo" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-slow" loading="lazy" />
              )}
            </div>
            <div class="p-6">
              <span class="text-xs font-normal uppercase tracking-widest text-gold">{post.data.category}</span>
              <h3 class="text-lg mt-2 mb-3 group-hover:text-gold transition-colors duration-base">{post.data.title}</h3>
              <p class="text-text-secondary text-sm leading-relaxed line-clamp-2">{post.data.description}</p>
              <time class="block mt-4 text-xs text-text-muted" datetime={post.data.pubDate.toISOString()}>
                {formatDate(post.data.pubDate)}
              </time>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
) : (
  <section class="section-padding bg-surface">
    <div class="container-narrow text-center" data-animate>
      <span class="text-gold text-sm font-normal uppercase tracking-[0.2em]">Blog</span>
      <h2 class="mt-4 mb-4">Dicas & Inspirações</h2>
      <div class="w-16 h-0.5 bg-gold mx-auto mb-6"></div>
      <p class="text-text-secondary leading-relaxed mb-8">
        Em breve publicaremos guias de decoração, cuidados com móveis externos e tendências de design para você criar ambientes únicos.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a
          href="/catalogo"
          class="inline-flex items-center justify-center min-h-[48px] px-8 bg-anthracite text-text-inverse text-sm font-normal rounded-[var(--radius-md)] hover:bg-anthracite-light transition-colors duration-base"
        >
          Explorar o Catálogo
        </a>
        <a
          href="/contato"
          class="inline-flex items-center justify-center min-h-[48px] px-8 border border-border text-text-primary text-sm font-normal rounded-[var(--radius-md)] hover:border-gold hover:text-gold transition-all duration-base"
        >
          Falar com a Equipe
        </a>
      </div>
    </div>
  </section>
)}
